# ─────────────────────────────────────────────────────────────
# Dumpsters on Demand — monorepo root .gitignore
# Per-project .gitignore files still apply inside each project.
# ─────────────────────────────────────────────────────────────

# macOS / editor noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Node
node_modules/

# Build outputs
dist/
build/
out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# Augment Skills — "lean repo" strategy
# ─────────────────────────────────────────────────────────────
# .agents/ holds the canonical (cloned) skill content.
# We IGNORE it here but keep:
#   - skills-lock.json        (at repo root) for reproducibility
#   - .augment/skills/*       (symlinks + copied single-skill dirs)
#
# Teammates restore .agents/ after clone with:
#   npx skills experimental_install
.agents/

# Other AI agents' skill directories (skills CLI creates one per supported tool).
# We use Augment, so keep .augment/ only. All other dot-agent dirs are ignored.
# (They're just symlinks into .agents/ which is itself ignored.)
.adal/
.bob/
.claude/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/
